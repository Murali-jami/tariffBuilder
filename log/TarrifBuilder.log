                        </div>
                    </div>
 
                    <div class="login-buttons">
                        <button type="reset" class="btn-cancel">Cancel</button>
                        <button type="submit" class="btn-submit">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
 
</body>
